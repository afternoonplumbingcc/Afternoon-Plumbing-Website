# Afternoon Plumbing Website
Environment variables for local development and production

# API Configuration
VITE_API_URL=http://localhost:3001/api
VITE_SITE_URL=https://afternoonplumbing.com

# Google Services (for SEO, Analytics, etc.)
VITE_GOOGLE_SITE_VERIFICATION=
VITE_GA_TRACKING_ID=

# Contact Form
VITE_CONTACT_EMAIL=info@afternoonplumbing.com
VITE_CONTACT_PHONE=(410) 555-1234

# Business Info
VITE_BUSINESS_NAME=Afternoon Plumbing
VITE_BUSINESS_ADDRESS=123 Main St, Westminster, MD 21157
VITE_SERVICE_AREA="Westminster, MD and surrounding areas within 20-mile radius"

# Feature Flags
VITE_ENABLE_CONTACT_FORM=true
VITE_ENABLE_QUOTE_CALCULATOR=true
VITE_ENABLE_TESTIMONIALS=true

# Build Configuration
VITE_BUILD_DATE=
